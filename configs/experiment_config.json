{
  "default_protocols": [
    "single_agent",
    "unstructured_group_chat",
    "sequential_handoff",
    "shared_blackboard",
    "manager_worker",
    "debate",
    "voting",
    "dynamic_task_allocation"
  ],
  "available_protocols": [
    "single_agent",
    "unstructured_group_chat",
    "sequential_handoff",
    "shared_blackboard",
    "manager_worker",
    "debate",
    "voting",
    "dynamic_task_allocation"
  ],
  "protocols": {
    "single_agent": {
      "max_rounds": 1,
      "max_interactions": 1
    },
    "unstructured_group_chat": {
      "max_rounds": 3,
      "max_interactions": 13
    },
    "sequential_handoff": {
      "max_rounds": 1,
      "max_interactions": 4
    },
    "shared_blackboard": {
      "max_rounds": 2,
      "max_interactions": 9
    },
    "manager_worker": {
      "max_rounds": 3,
      "max_interactions": 8
    },
    "debate": {
      "max_rounds": 2,
      "max_interactions": 7
    },
    "voting": {
      "max_rounds": 2,
      "max_interactions": 8
    },
    "dynamic_task_allocation": {
      "max_rounds": 3,
      "max_interactions": 15
    }
  },
  "task_visibility": {
    "agent_fields": [
      "task_id",
      "category",
      "difficulty",
      "tool_requirement",
      "available_tools",
      "tool_expectations",
      "prompt",
      "required_output_format"
    ],
    "allow_protected_fields_for_agents": false,
    "store_agent_prompts": true
  },
  "tool_policy": {
    "execution_layer": "local_function_tools",
    "available_tools": [
      "google_search_tool",
      "web_search",
      "fetch_url",
      "fetch_urls",
      "academic_search",
      "academic_lookup",
      "calculator",
      "list_local_documents",
      "read_local_document",
      "read_local_documents"
    ],
    "max_tool_rounds_per_interaction": 3,
    "max_tool_calls_per_interaction": 4,
    "timeout_seconds": 20,
    "max_result_chars": 24000,
    "local_document_roots": [
      "benchmark/documents"
    ],
    "record_tool_inputs": true,
    "record_tool_outputs": true
  },
  "run_policy": {
    "runs_per_condition": 1,
    "rerun_failed_conditions": false,
    "max_total_tokens": 100000,
    "final_writer_reserve_tokens": 20000,
    "minimum_call_output_tokens": 128,
    "token_estimation_bytes_per_token": 3.0,
    "token_safety_margin": 1000
  },
  "failure_taxonomy": [
    "None",
    "Coordination Failure",
    "Communication Failure",
    "Role Confusion",
    "Hallucination Propagation",
    "Premature Consensus",
    "Over-Collaboration",
    "Manager Bottleneck",
    "Noise Accumulation",
    "Other Failure"
  ],
  "failure_analysis": {
    "minimum_cases": 5,
    "minimum_task_fraction": 0.2
  }
}
